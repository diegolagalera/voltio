{
  "name": "fpsaver-backend",
  "version": "1.0.0",
  "description": "FPSaver - Industrial Energy Efficiency SaaS Backend",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "lsof -ti:3000 | xargs kill -9 2>/dev/null; nodemon src/app.js",
    "seed": "node src/db/seed.js",
    "migrate": "node src/db/migrate.js up",
    "migrate:down": "node src/db/migrate.js down",
    "migrate:redo": "node src/db/migrate.js redo",
    "migrate:create": "node src/db/migrate.js create",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "mqtt": "^5.10.4",
    "node-cron": "^4.2.1",
    "node-pg-migrate": "^8.0.4",
    "openai": "^6.27.0",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9"
  }
}
